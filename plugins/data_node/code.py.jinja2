{# Handler for block type: data #}
async def _type_handler_data(bot, chat_id, user_id, block_id, ctx, data, disable):
    action = data.get("action", "set")
    if action == "issue":
        product_id = resolve_text(str(data.get("productId") or "").strip(), user_id)
        content = issue_inventory_item(product_id, user_id)
        out_idx = 0 if content is not None else 1
        next_id = get_next_block(block_id, out_idx)
        if next_id:
            await execute_block(bot, chat_id, user_id, next_id, ctx)
        return
    raw_field = (data.get("fieldName") or "").strip()
    field_type = data.get("fieldType", "string")
    scope, _ = _parse_placeholder_key(raw_field) if raw_field else ("legacy", "")
    is_bot_scope = scope == "bot" or raw_field.lower().startswith("bot.")
    field = _normalize_bot_key(raw_field) if is_bot_scope else _normalize_user_field(raw_field)
    if not field:
        next_id = get_next_block(block_id, 0)
        if next_id:
            await execute_block(bot, chat_id, user_id, next_id, ctx)
        return
    if action == "set":
        src = data.get("valueSource", "const")
        if src == "input":
            next_id = get_next_block(block_id, 0)
            return ("await_input", {"block_id": block_id, "field": raw_field, "field_type": field_type, "next_id": next_id})
        raw_val = data.get("fieldValue")
        if raw_val is None:
            raw_val = ""
        val = resolve_text(str(raw_val), user_id)
        if field_type == "number":
            try:
                val = str(float(str(val).replace(",", ".")))
            except (ValueError, TypeError):
                val = "0"
        if is_bot_scope:
            set_bot_global(field, val)
        else:
            set_user_field(user_id, field, val)
    elif action == "add":
        if is_bot_scope:
            cur = get_bot_global(field)
        else:
            cur = get_user_field(user_id, field)
        try:
            cur_f = float(str(cur or "0").replace(",", "."))
        except (ValueError, TypeError):
            cur_f = 0
        delta_raw = data.get("fieldValue") or "0"
        delta = resolve_text(str(delta_raw), user_id)
        try:
            delta_f = float(str(delta).replace(",", "."))
        except (ValueError, TypeError):
            delta_f = 0
        new_val = str(cur_f + delta_f)
        if is_bot_scope:
            set_bot_global(field, new_val)
        else:
            set_user_field(user_id, field, new_val)
    elif action == "subtract":
        if is_bot_scope:
            cur = get_bot_global(field)
        else:
            cur = get_user_field(user_id, field)
        try:
            cur_f = float(str(cur or "0").replace(",", "."))
        except (ValueError, TypeError):
            cur_f = 0
        delta_raw = data.get("fieldValue") or "0"
        delta = resolve_text(str(delta_raw), user_id)
        try:
            delta_f = float(str(delta).replace(",", "."))
        except (ValueError, TypeError):
            delta_f = 0
        new_val = str(cur_f - delta_f)
        if is_bot_scope:
            set_bot_global(field, new_val)
        else:
            set_user_field(user_id, field, new_val)
    next_id = get_next_block(block_id, 0)
    if next_id:
        await execute_block(bot, chat_id, user_id, next_id, ctx)
