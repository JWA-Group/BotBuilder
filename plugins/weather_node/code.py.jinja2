    0: "Ясно",

    1: "Преимущественно ясно",

    2: "Переменная облачность",

    3: "Пасмурно",

    45: "Туман",

    48: "Изморозь",

    51: "Морось: слабая",

    53: "Морось: умеренная",

    55: "Морось: сильная",

    61: "Дождь: слабый",

    63: "Дождь: умеренный",

    65: "Дождь: сильный",

    71: "Снег: слабый",

    73: "Снег: умеренный",

    75: "Снег: сильный",

    80: "Ливень: слабый",

    81: "Ливень: умеренный",

    82: "Ливень: сильный",

    95: "Гроза",

